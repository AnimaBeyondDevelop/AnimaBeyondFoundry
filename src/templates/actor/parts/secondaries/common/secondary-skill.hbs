{{#> "systems/animabf/templates/common/ui/group.hbs"
  class=this.secondarySkillName
}}
  {{>
  "systems/animabf/templates/common/ui/group-header.hbs"
    title=(localize (concat "anima.ui.secondaries." this.secondarySkillName ".title"))
  }}
  {{#> "systems/animabf/templates/common/ui/group-body.hbs"
    class=this.secondarySkillName
  }}
    {{#each this.secondarySkills as |atr key|}}
      {{>
        "systems/animabf/templates/common/ui/types/secondary-ability.hbs"
        cssClass="name"
        title=(localize (concat "anima.ui.secondaries." key ".title"))
        rollable=true
        path=(concat "system.secondaries." ../this.secondarySkillName "." key)
        value=atr
      }}
    {{/each}}
  {{/"systems/animabf/templates/common/ui/group-body.hbs"}}
{{/"systems/animabf/templates/common/ui/group.hbs"}}