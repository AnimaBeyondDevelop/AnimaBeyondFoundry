{{#> "systems/animabf/templates/common/ui/group.hbs"
  class="resistances"
}}
  {{>
  "systems/animabf/templates/common/ui/group-header.hbs"
    title=(localize "anima.ui.resistances.title")
  }}
  {{#> "systems/animabf/templates/common/ui/group-body.hbs"
    class="resistances"
  }}
    {{#each system.characteristics.secondaries.resistances as |atr key|}}
      {{>
      "ui/types/resistance"
        cssClass="resistance"
        rollable=true
        path=(concat "system.characteristics.secondaries.resistances." key)
        value=atr
        title=(localize (concat 'anima.ui.resistances.' key))
        rollableDice=@root.system.general.diceSettings.resistanceDie.value
        rollableMessage=(localize (concat 'anima.ui.resistances.' key))
      }}
    {{/each}}
  {{/"systems/animabf/templates/common/ui/group-body.hbs"}}
{{/"systems/animabf/templates/common/ui/group.hbs"}}
