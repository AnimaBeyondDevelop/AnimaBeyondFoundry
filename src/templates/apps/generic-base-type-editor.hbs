<form>
  <p><strong>{{type}}</strong></p>

  {{#each fields as |f|}}
    <div class="form-group">
      <label>{{f.label}}</label>

      {{#if (is "eq" f.kind "number")}}
        <input
          type="number"
          name="{{f.fieldPath}}"
          value="{{getProperty ../values f.fieldPath (getProperty ../defaults f.fieldPath)}}"
          {{#if f.readonly}}disabled{{/if}}
        />
      {{else if (is "eq" f.kind "bool")}}
        <input
          type="checkbox"
          name="{{f.fieldPath}}"
          {{checked (getProperty ../values f.fieldPath (getProperty ../defaults f.fieldPath))}}
          {{#if f.readonly}}disabled{{/if}}
        />
      {{else if (is "eq" f.kind "select")}}
        {{!-- Robust current value: values -> defaults; supports primitive or {value:primitive} --}}
        {{#with (getProperty ../values f.fieldPath (getProperty ../defaults f.fieldPath)) as |raw|}}
          {{#with (getProperty raw "value" raw) as |cur|}}
            <select name="{{f.fieldPath}}" {{#if f.readonly}}disabled{{/if}}>
              {{#each f.options as |o|}}
                <option
                  value="{{o.value}}"
                  {{#if (is "eq" cur o.value)}}selected{{/if}}
                >
                  {{o.label}}
                </option>
              {{/each}}
            </select>
          {{/with}}
        {{/with}}
      {{else}}
        <input
          type="text"
          name="{{f.fieldPath}}"
          value="{{getProperty ../values f.fieldPath (getProperty ../defaults f.fieldPath)}}"
          {{#if f.readonly}}disabled{{/if}}
        />
      {{/if}}
    </div>
  {{/each}}

  <footer class="sheet-footer flexrow">
    <button type="submit">
      <i class="fas fa-save"></i> Save
    </button>
  </footer>
</form>